{
  "name": "@agentium/eval",
  "version": "2.0.7",
  "description": "Evaluation framework for testing and scoring Agentium agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentiumOS/agentium.git",
    "directory": "packages/eval"
  },
  "keywords": [
    "ai",
    "agents",
    "eval",
    "testing",
    "scoring",
    "benchmarks"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --shims --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --shims --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@agentium/core": "^2.0.7"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "homepage": "https://agentium.in",
  "bugs": {
    "url": "https://github.com/agentiumOS/agentium/issues"
  }
}
