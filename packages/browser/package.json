{
  "name": "@agentium/browser",
  "version": "2.0.6",
  "description": "Browser automation agent for Agentium using Playwright",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentiumOS/agentium.git",
    "directory": "packages/browser"
  },
  "keywords": [
    "ai",
    "agents",
    "browser",
    "automation",
    "playwright",
    "scraping"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --shims --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --shims --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "playwright": "^1.58.2",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "@agentium/core": "^2.0.6",
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": false
    }
  },
  "homepage": "https://agentium.in",
  "bugs": {
    "url": "https://github.com/agentiumOS/agentium/issues"
  }
}
