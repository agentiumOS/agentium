{
  "name": "@agentium/cli",
  "version": "2.0.0",
  "description": "Command-line tool for scaffolding and managing Agentium projects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentiumOS/agentium.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "agentium"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentium": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm,cjs --dts --shims --clean",
    "dev": "tsup src/index.ts src/bin.ts --format esm,cjs --dts --shims --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "@agentium/core": "^2.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "prompts": "^2.4.2"
  }
}
