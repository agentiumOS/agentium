{
  "name": "@agentium/core",
  "version": "2.3.1",
  "description": "Core framework for building AI agents with tools, memory, and multi-model support",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentiumOS/agentium.git",
    "directory": "packages/core"
  },
  "keywords": [
    "ai",
    "agents",
    "llm",
    "openai",
    "anthropic",
    "tools",
    "memory"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/tools/sandbox-worker.ts --format esm,cjs --dts --shims --clean",
    "dev": "tsup src/index.ts src/tools/sandbox-worker.ts --format esm,cjs --dts --shims --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
