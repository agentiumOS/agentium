{
  "name": "@agentium/edge",
  "version": "1.0.0",
  "description": "Edge deployment for Agentium — IoT toolkits (GPIO, sensors, camera, BLE), edge runtime, and Ollama helpers for Raspberry Pi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentiumOS/agentium.git",
    "directory": "packages/edge"
  },
  "keywords": [
    "ai",
    "agents",
    "edge",
    "iot",
    "raspberry-pi",
    "gpio",
    "ollama",
    "agentium"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --shims --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --shims --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "@agentium/core": "^1.0.0",
    "node-libgpiod": ">=0.4.0",
    "i2c-bus": ">=5.0.0",
    "@stoprocent/noble": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "node-libgpiod": {
      "optional": true
    },
    "i2c-bus": {
      "optional": true
    },
    "@stoprocent/noble": {
      "optional": true
    }
  }
}
